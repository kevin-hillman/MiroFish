# LLM-API-Konfiguration (unterstuetzt jede LLM-API im OpenAI-SDK-Format)
# Empfohlen: qwen-plus-Modell auf der Alibaba-Bailian-Plattform: https://bailian.console.aliyun.com/
# Achtung: Hoher Verbrauch - bitte zuerst eine Simulation mit weniger als 40 Runden testen
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP-Gedaechnisgraph-Konfiguration =====
# Das monatliche Freikontingent reicht fuer einfache Nutzung aus: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Beschleunigte LLM-Konfiguration (optional) =====
# Achtung: Wenn die Beschleunigungskonfiguration nicht verwendet wird, sollten die folgenden Eintraege nicht in der .env-Datei erscheinen
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Authentifizierung (optional) =====
# Supabase Auth aktivieren (true/false)
AUTH_ENABLED=false
# Supabase Projekt-URL und Keys (von https://supabase.com Dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret